[bandit]
# Bandit security scanner configuration for GeneWeb Python project
# https://bandit.readthedocs.io/

# Exclude test files and generated code
exclude_dirs = ["/tests", "/.venv", "/venv", "/__pycache__"]

# Target directories for scanning
targets = ["core"]

# Test levels: LOW, MEDIUM, HIGH
severity = MEDIUM

# Confidence levels: LOW, MEDIUM, HIGH
confidence = MEDIUM

# Skip specific tests if needed (uncomment and modify as needed)
# skips = B101,B601
